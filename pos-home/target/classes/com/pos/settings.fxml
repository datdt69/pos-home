<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.pos.controller.SettingsController"
            styleClass="app-screen app-fill settings-screen" minWidth="600" minHeight="480" maxWidth="Infinity" maxHeight="Infinity">
    <top>
        <VBox spacing="6" styleClass="card">
            <padding>
                <Insets top="10" right="12" bottom="8" left="12"/>
            </padding>
            <Label text="Cài đặt" styleClass="section-title"/>
        </VBox>
    </top>
    <center>
        <GridPane hgap="12" vgap="12" maxWidth="720" styleClass="settings-grid">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints minWidth="120" maxWidth="160" hgrow="NEVER"/>
                <ColumnConstraints minWidth="200" hgrow="ALWAYS" maxWidth="600"/>
            </columnConstraints>
            <Label text="Cổng in (COM)&#10;⚠ nếu chưa kết nối" styleClass="subtle" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="0" alignment="TOP_LEFT"/>
            <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="cmbPort" prefWidth="200" minHeight="40" styleClass="combo-filter" maxWidth="320"/>
                    <Button text="Làm mới" onAction="#onRefreshPorts" styleClass="btn btn-secondary" minHeight="40"/>
                </HBox>
                <Button text="Tự tìm máy in" onAction="#onAutoDetect" styleClass="btn btn-secondary" minHeight="36"/>
            </VBox>
            <Label text="Tốc độ (baud)&#10;nhiều máy: 115200" styleClass="subtle" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="0" alignment="TOP_LEFT"/>
            <ComboBox fx:id="cmbBaud" prefWidth="180" minHeight="40" styleClass="combo-filter" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Khổ giấy" styleClass="subtle" GridPane.rowIndex="2" GridPane.columnIndex="0" alignment="CENTER_LEFT"/>
            <ComboBox fx:id="cmbPaper" prefWidth="180" minHeight="40" styleClass="combo-filter" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Tên cửa hàng" styleClass="subtle" GridPane.rowIndex="3" GridPane.columnIndex="0" alignment="CENTER_LEFT"/>
            <TextField fx:id="txtShopName" minHeight="40" maxWidth="Infinity" styleClass="search-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="Địa chỉ" styleClass="subtle" GridPane.rowIndex="4" GridPane.columnIndex="0" alignment="TOP_LEFT"/>
            <TextField fx:id="txtAddress" minHeight="40" maxWidth="Infinity" styleClass="search-field" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            <Label text="Số điện thoại" styleClass="subtle" GridPane.rowIndex="5" GridPane.columnIndex="0" alignment="CENTER_LEFT"/>
            <TextField fx:id="txtPhone" minHeight="40" maxWidth="Infinity" styleClass="search-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            <Label text="Ghi chú" styleClass="subtle" wrapText="true" GridPane.rowIndex="6" GridPane.columnIndex="0" alignment="TOP_LEFT"/>
            <Label fx:id="lblSettingsPath" styleClass="result-count" wrapText="true" maxWidth="560" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="card">
            <padding>
                <Insets top="8" right="12" bottom="12" left="12"/>
            </padding>
            <Button text="In thử" onAction="#onTestPrint" styleClass="btn btn-secondary" minHeight="40"/>
            <Button text="Lưu cài đặt" onAction="#onSave" styleClass="btn-accent" minHeight="40"/>
        </HBox>
    </bottom>
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>
